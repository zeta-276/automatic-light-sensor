// pin numbers
int led = 2;
int res = A0;

void setup() {
  pinMode(led,OUTPUT);
  pinMode(res,OUTPUT);
  Serial.begin(9600);
}
// define threshold for LDR
void loop() {
 analogRead(res); 
 Serial.println(analogRead(res));  // with 1 kΩ resistor
  if (analogRead(res) >= 50) {
    digitalWrite(led, LOW);        // light off
  }
  else {
    digitalWrite(led, HIGH);       // light on
  }
}
